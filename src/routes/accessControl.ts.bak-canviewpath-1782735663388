function normalizeText(value: unknown) {
  return String(value || "")
    .trim()
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "_")
    .replace(/^_+|_+$/g, "");
}

function splitText(value: unknown): string[] {
  if (Array.isArray(value)) {
    return value.flatMap((item) => splitText(item));
  }

  return String(value || "")
    .split(/[,|;]/)
    .map((item) => item.trim())
    .filter(Boolean);
}

export function getUserRoles(user: AccessUser | null | undefined): string[] {
  const roles = [
    ...splitText(user?.roles),
    ...splitText(user?.roleName),
    ...splitText(user?.RoleName),
    ...splitText(user?.role),
    ...splitText(user?.Role),
  ];

  return Array.from(new Set(roles.map(normalizeText).filter(Boolean)));
}

export function isSuperAccessUser(user: AccessUser | null | undefined) {
  const roles = getUserRoles(user);
  return Boolean(user?.isSuperAdmin || user?.isSystemAdmin) ||
    roles.some((role) =>
      ["super_admin", "superadmin", "system_administrator", "system_admin", "admin"].includes(role)
    );
}

function normalizeRoute(pathname: string) {
  const path = String(pathname || "/").split("?")[0].split("#")[0];
  if (!path || path === "/") return "/";
  return path.length > 1 && path.endsWith("/") ? path.slice(0, -1) : path;
}

function routeMatches(pathname: string, allowedRoute: string) {
  const path = normalizeRoute(pathname);
  const allowed = normalizeRoute(allowedRoute);
  return path === allowed || path.startsWith(allowed + "/");
}

function getRoleAllowedRoutes(user: AccessUser | null | undefined): string[] {
  const roles = getUserRoles(user);

  for (const role of roles) {
    if (ROLE_ROUTE_ALLOW_LIST[role]) {
      return ROLE_ROUTE_ALLOW_LIST[role];
    }
  }

  return [];
}

function getUserConfiguredRoutes(user: AccessUser | null | undefined): string[] {
  const allowedRoutes = Array.isArray(user?.allowedRoutes) ? user.allowedRoutes.map(String) : [];
  const allowedModules = Array.isArray(user?.allowedModules) ? user.allowedModules.map(String) : [];
  const moduleAccess = user?.moduleAccess && typeof user.moduleAccess === "object" ? user.moduleAccess : {};

  const fromModuleAccess = Object.values(moduleAccess)
    .map((item: any) => item?.routePath || item?.route || item?.path || "")
    .filter(Boolean)
    .map(String);

  return [...allowedRoutes, ...allowedModules, ...fromModuleAccess].filter(Boolean);
}

export function getAllowedRoutesForUser(user: AccessUser | null | undefined): string[] {
  if (!user) return [];

  const roleRoutes = getRoleAllowedRoutes(user);

  // Important:
  // Restrictive business roles must win over backend wildcard.
  // This prevents Dashboard Manager from getting all pages when API returns allowedRoutes ["*"].
  if (roleRoutes.length > 0 && !roleRoutes.includes("*")) {
    return roleRoutes;
  }

  if (isSuperAccessUser(user)) return ["*"];
  if (roleRoutes.includes("*")) return ["*"];

  const configuredRoutes = getUserConfiguredRoutes(user);
  if (configuredRoutes.includes("*")) return ["*"];

  const realRoutes = configuredRoutes.filter((route) => route.startsWith("/"));
  if (realRoutes.length > 0) return Array.from(new Set(realRoutes));

  return [];
}

export function canAccessRoute(user: AccessUser | null | undefined, pathname: string) {
  const path = normalizeRoute(pathname);

  if (path === "/" || path === "/login") return true;

  const allowedRoutes = getAllowedRoutesForUser(user);

  if (allowedRoutes.includes("*")) return true;

  return allowedRoutes.some((route) => routeMatches(path, route));
}

export function getDefaultRouteForUser(user: AccessUser | null | undefined) {
  const allowedRoutes = getAllowedRoutesForUser(user);

  if (allowedRoutes.includes("*")) return "/dashboard";

  for (const route of ROUTE_ORDER) {
    if (allowedRoutes.some((allowed) => routeMatches(route, allowed))) {
      return route;
    }
  }

  return "/login";
}
